# ===========================================
# Kids Learning Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ---------- Backend (.env in backend folder) ----------

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/kids-learning

# For MongoDB Atlas (recommended for production):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/kids-learning?retryWrites=true&w=majority

# Ollama AI Configuration (Local LLM - Free)
# Download Ollama from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Claude API Configuration (Fallback - Paid)
# Get API key from: https://console.anthropic.com
CLAUDE_API_KEY=your-claude-api-key-here

# Parent PIN for Break Override
PARENT_PIN=1234


# ---------- Frontend (.env.local in frontend folder) ----------

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# App Configuration
NEXT_PUBLIC_APP_NAME=Kids Learning Platform
NEXT_PUBLIC_VERSION=1.0.0
